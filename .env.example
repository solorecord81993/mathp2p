# Copy this file to .env for local testing (Render/Railway: set these as dashboard env vars instead).

# Port the server listens on. Render/Railway set this automatically — you usually don't need to set it yourself.
PORT=8080

# Optional but recommended: an Euler Stream API key (free tier available at https://www.eulerstream.com).
# tiktok-live-connector needs a signing backend to open a TikTok LIVE connection; without a key it may
# still work on the shared free tier but can be rate-limited or blocked. See bridge-server/README.md.
EULERSTREAM_API_KEY=
